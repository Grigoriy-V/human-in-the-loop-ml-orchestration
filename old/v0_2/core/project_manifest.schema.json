{
  "title": "Core immutable ownership manifest",
  "schema_vocabulary": "bundled-core-manifest-v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "core_repository",
    "core_version",
    "owned_files",
    "mutable_boundaries"
  ],
  "properties": {
    "core_repository": {
      "const": "human-in-the-loop-ml-orchestration"
    },
    "core_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "owned_files": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      }
    },
    "mutable_boundaries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
