{
  "schema_vocabulary": "bundled-core-pin-v2",
  "contract_note": "tools/validate_core_pin.py is authoritative; no complete JSON Schema Draft implementation is claimed.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "core_repository",
    "core_version",
    "core_commit",
    "adapter_type",
    "adapter_name",
    "managed_manifest",
    "managed_files"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "core_repository": {
      "const": "human-in-the-loop-ml-orchestration"
    },
    "core_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "core_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "adapter_type": {
      "enum": [
        "generic",
        "classical_ml"
      ]
    },
    "adapter_name": {
      "type": "string",
      "minLength": 1
    },
    "managed_manifest": {
      "const": "core/managed_files.json"
    },
    "managed_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target_path",
          "target_sha256",
          "core_path",
          "core_sha256",
          "relationship"
        ],
        "properties": {
          "target_path": {
            "type": "string",
            "minLength": 1
          },
          "target_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "core_path": {
            "type": "string",
            "minLength": 1
          },
          "core_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "relationship": {
            "enum": [
              "base_copy",
              "overlay_copy"
            ]
          }
        }
      }
    }
  }
}
